{
  "name": "sdd-pack",
  "owner": { "name": "norman" },
  "metadata": {
    "description": "sdd-pack 一体化开发管理工具：SDD 技能家族(sdd-core/input/prd/phase) + 三层守门 agent(reviewer/arch-reviewer/sdd-reviewer) + SDD extension(/sdd-*) + SDD CI runner",
    "version": "1.6.0",
    "pluginRoot": "plugins"
  },
  "plugins": [
    {
      "name": "sdd-pack",
      "description": "SDD 一体化工具(正本)",
      "source": "./sdd-pack",
      "category": "development",
      "keywords": [
        "sdd",
        "prd",
        "phase",
        "lore",
        "gate",
        "documentation",
        "reviewer",
        "code-review",
        "architecture",
        "quality-gate",
        "solid",
        "cohesion",
        "coupling"
      ],
      "version": "1.6.0",
      "assets": {
        "skills": ["sdd-core", "sdd-input", "sdd-prd", "sdd-phase"],
        "rules": [
          "lore-protocol",
          "docs-update-guard",
          "lore-commit-guard",
          "sdd-doc-edit-guard",
          "prd-change-management"
        ],
        "agents": ["reviewer", "arch-reviewer", "sdd-reviewer"],
        "commands": [
          "/sdd",
          "/sdd-validate",
          "/sdd-propose",
          "/sdd-archive",
          "/sdd-archive-phase",
          "/sdd-migrate",
          "/sdd-status",
          "/sdd-list",
          "/sdd-why",
          "/sdd-apply",
          "/sdd-gate-lint",
          "/sdd-gate-test",
          "/sdd-gate-review",
          "/sdd-gate-precommit",
          "/sdd-gate-commit"
        ],
        "hooks": []
      },
      "paradigm": {
        "primary": "sdd"
      },
      "reviewer_layers": {
        "layer_1_commit": { "agent": "reviewer", "blocking": true, "verdict_field": "overall_correctness" },
        "layer_2_pr_plan": { "agent": "arch-reviewer", "blocking": false, "verdict_field": "overall_quality" },
        "layer_3_merge_phase": { "agent": "sdd-reviewer", "blocking": false, "verdict_field": "overall_conformance" }
      },
      "rule_enforcement": {
        "model": "ttsr",
        "explanation": "5 个 rule 全部是 TTSR 软门禁：omp plugin link 后由 omp-plugins provider 自动发现，tool_call 时注入 system 提示，由主 agent 自觉遵守。程序级硬门禁由 extension 内嵌的 pi.on(\"tool_call\") 拦截 + /sdd-gate-* slash command + gate-runner.ts 提供。"
      }
    }
  ]
}
